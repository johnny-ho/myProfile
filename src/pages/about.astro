---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { BASE } from '@/lib/base';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const skills = [
  'Product Strategy',
  'Roadmap Planning',
  'Agile / Scrum',
  'User Research',
  'Stakeholder Management',
  'B2B SaaS',
  'Enterprise Platforms',
  'Cloud / FinOps',
  'AI Tools',
  'Cross-functional Leadership',
];

interface Job {
  company: string;
  role: string;
  period: string;
  summary: string;
}

// TODO: Update with complete LinkedIn experience once provided
const experience: Job[] = [
  {
    company: 'TSMC (台積電)',
    role: 'Senior Product Manager',
    period: '2021 – Present',
    summary: 'Leading product strategy and roadmap for enterprise-facing digital platforms at the world\'s leading semiconductor company.',
  },
];
---

<BaseLayout title="About" description="Chang-Wen Ho (Johnny) — Senior Product Manager based in Hsinchu, Taiwan.">
  <div class="about-page">

    <!-- Profile Header -->
    <section class="profile-header">
      <div class="avatar-wrap">
        <img
          src="https://media.licdn.com/dms/image/v2/D5603AQEKd45XwTkjJQ/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1698833700979?e=1753315200&v=beta&t=linkedin-photo"
          alt="Chang-Wen Ho"
          onerror="this.style.display='none'; this.parentElement.querySelector('.avatar-fallback').style.display='flex';"
        />
        <div class="avatar-fallback" style="display:none">JH</div>
      </div>
      <div class="profile-info">
        <h1>Chang-Wen Ho <span class="alias">(Johnny)</span></h1>
        <p class="role">Senior Product Manager</p>
        <p class="location">📍 Hsinchu, Taiwan</p>
        <div class="social-links">
          <a href="https://www.linkedin.com/in/changwenho/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </section>

    <!-- Bio -->
    <section class="bio">
      <h2>About</h2>
      <p>
        I make complex systems feel simple. As a Senior Product Manager with over a decade of
        experience, I've built products at the intersection of deep technology and human workflow —
        from semiconductor fab platforms to enterprise SaaS tools used by thousands of internal users.
      </p>
      <p>
        What sets me apart isn't just knowing how to write a PRD or run a sprint — it's the ability
        to walk into a room full of engineers, operators, and executives, and leave with everyone
        aligned on what matters and why. I've learned that great product work is 30% vision and
        70% trust.
      </p>
      <p>
        I'm genuinely excited about how AI is reshaping the PM role — not by replacing judgment,
        but by amplifying it. I experiment constantly with tools like Claude and Cursor to work
        faster and think sharper. I write about what I learn, because the best way to refine
        thinking is to share it.
      </p>
    </section>

    <!-- Skills -->
    <section class="skills-section">
      <h2>Skills & Expertise</h2>
      <div class="skills-grid">
        {skills.map(skill => <span class="tag">{skill}</span>)}
      </div>
    </section>

    <!-- Experience -->
    <section class="experience-section">
      <h2>Experience</h2>
      <div class="timeline">
        {experience.map(job => (
          <div class="job">
            <div class="job-header">
              <div>
                <strong>{job.company}</strong>
                <span class="job-role">{job.role}</span>
              </div>
              <span class="job-period">{job.period}</span>
            </div>
            <p class="job-summary">{job.summary}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Recent Writing -->
    {recentPosts.length > 0 && (
      <section class="recent-writing">
        <div class="section-header">
          <h2>Recent Writing</h2>
          <a href={`${BASE}/talk`}>All posts →</a>
        </div>
        <div class="post-list">
          {recentPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.slug}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .about-page {
    padding: 3rem 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Profile Header */
  .profile-header { display: flex; gap: 2rem; align-items: flex-start; }

  .avatar-wrap img,
  .avatar-fallback {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-border);
    flex-shrink: 0;
  }

  .avatar-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .profile-info { flex: 1; }
  .profile-info h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
  .alias { color: var(--color-text-muted); font-weight: 400; font-size: 1.4rem; }
  .role { color: var(--color-accent); font-weight: 500; margin: 0; }
  .location { color: var(--color-text-muted); font-size: 0.9rem; margin: 0.25rem 0; }

  .social-links { margin-top: 0.75rem; display: flex; gap: 0.75rem; }
  .social-links a { font-size: 0.85rem; font-weight: 500; }

  /* Section headings */
  section h2 {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Bio */
  .bio p { line-height: 1.75; color: var(--color-text-muted); }

  /* Skills */
  .skills-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* Experience */
  .timeline { display: flex; flex-direction: column; gap: 0; }

  .job {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .job:first-child { padding-top: 0; }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .job-header strong { font-size: 0.95rem; }

  .job-role {
    display: block;
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-top: 0.1rem;
  }

  .job-period {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Recent Writing */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header h2 {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .section-header a { font-size: 0.85rem; color: var(--color-text-muted); }

  .post-list { display: flex; flex-direction: column; gap: 1rem; }

  @media (max-width: 560px) {
    .profile-header { flex-direction: column; align-items: center; text-align: center; }
    .social-links { justify-content: center; }
    .job-header { flex-direction: column; gap: 0.15rem; }
  }
</style>

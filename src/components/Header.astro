---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header>
  <nav class="container">
    <a href="/" class="logo">Johnny Ho</a>
    <ul>
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'active' : ''}
          >{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0 1.5rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  ul a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  ul a:hover {
    color: var(--color-text);
    background: var(--color-surface);
    text-decoration: none;
  }

  ul a.active {
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .logo { font-size: 0.95rem; }
    ul a { font-size: 0.82rem; padding: 0.3rem 0.5rem; }
  }
</style>

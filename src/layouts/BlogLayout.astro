---
import BaseLayout from './BaseLayout.astro';

import { BASE } from '@/lib/base';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
}

const { title, description, date, category } = Astro.props;

const categoryLabels: Record<string, string> = {
  'product-experience': '產品經驗談',
  'product-perspectives': '產品觀點',
  'career-growth': '職涯成長',
  'ai-tools': 'AI / 工具應用',
};

const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <header>
      <div class="meta">
        <a href={`${BASE}/blog`} class="back">← All posts</a>
        <span class="tag">{categoryLabels[category] ?? category}</span>
      </div>
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formatted}</time>
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0 4rem;
  }

  header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .content {
    line-height: 1.75;
  }

  .content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .content :global(p) {
    margin-top: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-top: 0.35rem;
  }

  .content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin: 1.25rem 0;
  }

  @media (max-width: 600px) {
    h1 { font-size: 1.6rem; }
  }
</style>
